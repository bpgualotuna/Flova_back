# Base de Datos PostgreSQL
# Para desarrollo local:
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_base_datos
# Para Neon (Cloud) - Configura esto en las variables de entorno de Render, NO aquí:
# DATABASE_URL=postgresql://usuario:password@tu-proyecto.region.neon.tech/database?sslmode=require

# JWT
JWT_SECRET=cambia_este_secreto_por_uno_seguro
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173
